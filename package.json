    "dev:v4": "node tools/dev-version.mjs v4",
    "build": "tsc && vite build",
    "build:v1": "node tools/build-version.mjs v1",
    "build:v2": "node tools/build-version.mjs v2",
    "build:v3-old": "node tools/build-version.mjs v3-old",
    "build:v3": "node tools/build-version.mjs v3",
    "build:v4": "node tools/build-version.mjs v4",
    "build:android": "node tools/build-version.mjs android-v2",
